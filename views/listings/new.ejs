<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3>Create a New Listing</h3>
        <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data ">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input name="listing[title]" placeholder="Add a catchy title" type="text" class="form-control" required>
                <div class="valid-feedback">
        Good one!!
      </div>          
      <div class="invalid-feedback">
        Please Enter Title.
      </div> 
            </div>
            
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea name="listing[description]" class="form-control" placeholder="enter description" required></textarea>         
      <div class="invalid-feedback">
        Please Elaborate about your listing.
      </div> 
            </div>

            <div class="mb-3">
                <label for="image" class="form-label">Upload image</label>
                <input name="listing[image]" placeholder="Upload an image" type="file" class="form-control">
            </div>
            
            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <input name="listing[price]" placeholder="1200" type="number" class="form-control" required>          
      <div class="invalid-feedback">
        Enter the price.
      </div> 
                </div>
    
                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label">Country</label>
                    <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
                    <div class="valid-feedback">
        Amazing Country.
      </div>          
      <div class="invalid-feedback">
        Please Enter Country.
      </div>                
                </div>
            </div>
            
            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input name="listing[location]" placeholder="Jaipur, Rajasthan" type="text" class="form-control" required>
                <div class="valid-feedback">
       Beautiful Place!
      </div>          
      <div class="invalid-feedback">
        Please enter the location.
      </div> 
            </div>
            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <select name="listing[category]" id="category" class="form-control" required>
                    <% for (let category of categories) { %>
                        <option value="<%= category %>"><%= category %></option>
                    <% } %>
                </select>
            </div>
            <button class="btn btn-dark add-btn">Add</button>
        </form>
    </div>
</div>
