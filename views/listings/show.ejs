<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h3><%= listing.title %></h3>
    </div>
    <div class="card col-6 offset-2 show-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
        <div class="card-body">
            <p class="card-text mb-2"><%= listing.description %></p>
            <p class="card-text mb-1">&#8377; <%= listing.price %> / night</p>
            <p class="card-text mb-1"><%= listing.location %>, <%= listing.country %></p>
            <p class="card-text mb-0"><strong>Owner:</strong> <%= listing.owner ? listing.owner.username || listing.owner.email || "Owner" : "Unknown" %></p>
            <% if (listing.owner && currentUser && listing.owner._id.toString() === currentUser._id.toString()) { %>
                <div class="btns">
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn show-btn">Edit</a>
                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-dark show-btn">Delete</button>
                    </form>
                </div>
            <% } %>
        </div>
    </div>
    <div class="col-8 offset-2">
        <hr>
        <h4>Leave a review</h4>
        <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
                <label for="rating">rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div class="mb-3 mt-3">
                <label for="comment">comment</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="5"
                    class="form-control" required></textarea>
                <div class="invalid-feedback">Please submit comments</div>
            </div>

            <button class="btn btn-dark">Submit</button>
        </form>

        <hr />
    <h4 class="mb-3">All Reviews</h4>
<hr />


<div class="row">
  <% if (listing.reviews && listing.reviews.length > 0) { %>
    <% for (let review of listing.reviews) { %>
      <div class="col-md-6 mb-3">
        <div class="card shadow-sm border-0">
          <div class="card-body">
            <h6 class="card-subtitle mb-2 text-muted">
               Rating: <%= review.rating %> / 5
            </h6>
            <p class="card-text"><small><strong>By <%= review.owner ? review.owner.username || review.owner.email || "User" : "Anonymous" %></strong></small></p>
            <p class="card-text"><%= review.comment %></p>
            <p class="text-end text-secondary small mb-2">
              Posted on <%= new Date(review.createdAt).toLocaleDateString() %>
            </p>
            <% if (review.owner && currentUser && review.owner._id.toString() === currentUser._id.toString()) { %>
              <form class="mb-0" method="POST" action="/listings/<%= listing._id%>/reviews/<%=review._id%>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
  <% } else { %>
    <div class="col-12">
      <div class="alert alert-secondary" role="alert">
        No reviews yet! Be the first to leave one.
      </div>
    </div>
  <% } %>
</div>


     </div>
</div>
