<% layout("/layouts/boilerplate") %>
<%
    const selectedCategorySafe = typeof selectedCategory !== "undefined" ? selectedCategory : "";
    const filterOptionsSafe = typeof filterOptions !== "undefined"
        ? filterOptions
        : [
            { label: "Trending", icon: "fa-fire" },
            { label: "Rooms", icon: "fa-bed" },
            { label: "Beachfront", icon: "fa-umbrella-beach" },
            { label: "Cabins", icon: "fa-tree" },
            { label: "Castles", icon: "fa-chess-rook" },
            { label: "Camping", icon: "fa-campground" },
            { label: "Arctic", icon: "fa-snowflake" },
            { label: "Pools", icon: "fa-person-swimming" },
            { label: "Countryside", icon: "fa-mountain" },
            { label: "Luxury", icon: "fa-gem" },
            { label: "City", icon: "fa-city" },
            { label: "Farms", icon: "fa-tractor" },
        ];
%>


        <!-- <h3>Listings</h3> -->
        <!-- <form method="GET" action="/listings/new">
        <button>Add listing</button>
    </form>
    -->
        <section class="explore-hero">
            <h2>Explore Cozy Stays</h2>
            <p>Discover weekend cabins, beach homes, and stylish city stays.</p>
        </section>

        <div id="filters">
            <a class="filter-chip <%= selectedCategorySafe ? '' : 'active-filter' %>" href="/listings">
                <i class="fa-solid fa-border-all"></i>
                All
            </a>
            <% for (let option of filterOptionsSafe) { %>
                <a class="filter-chip <%= selectedCategorySafe === option.label ? 'active-filter' : '' %>"
                    href="/listings?category=<%= encodeURIComponent(option.label) %>">
                    <i class="fa-solid <%= option.icon %>"></i>
                    <%= option.label %>
                </a>
            <% } %>
        </div>
        <% if (allListings.length === 0) { %>
            <section class="empty-explore-state mt-4">
                <h4>No stays listed yet</h4>
                <p>
                    <%= selectedCategorySafe ? `No stays found in ${selectedCategorySafe}. Try another category or add one.` : 'Be the first to add a home and make this Explore page come alive.' %>
                </p>
                <a class="btn btn-dark" href="/listings/new">Add First Home</a>
            </section>
        <% } else { %>
            <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
                <% for(let listing of allListings){ %>
                    <a href="/listings/<%= listing._id%>">
                        <div class="card listing-card col" style="width: 20rem;">
                            <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image"
                                style="height: 20rem;">
                            <div class="card-body">
                                <p class="card-text">
                                    <%= listing.title%><br />
                                        &#8377;<%= listing.price %>/night<br />
                                </p>
                            </div>
                        </div>
                    </a>
                <% } %>
            </div>
        <% } %>
